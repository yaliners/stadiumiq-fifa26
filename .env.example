# GEMINI_API_KEY: Required for Gemini AI API calls.
# Automatically injected at runtime from secure secrets.
# Configure this via the secrets configuration panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this service is hosted.
# Automatically injected at runtime with the service deployment URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Shared Passcodes for Staff/Organizer/Volunteer roles
STAFF_ACCESS_CODE="staff123"
ORGANIZER_ACCESS_CODE="organizer123"
VOLUNTEER_ACCESS_CODE="volunteer123"

# Google Identity Services (GIS) Client ID for Google Sign-In
VITE_GOOGLE_CLIENT_ID=""

# Firebase Web App Credentials and Database configurations
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIRESTORE_DATABASE_ID=""
