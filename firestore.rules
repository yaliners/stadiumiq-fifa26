rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net (Default Deny Catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // 2. User Profiles
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null || (request.resource.data.uid == userId || request.resource.data.email is string);
    }

    // 3. Activity Logs
    match /activity_logs/{logId} {
      allow read: if true;
      allow write: if request.resource.data.action is string && request.resource.data.action.size() <= 256;
    }

    // 4. Matches
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null || request.resource.data.home_team is string;
    }
  }
}
