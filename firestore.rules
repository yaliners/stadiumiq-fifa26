rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net (Default Deny Catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // 2. User Profiles - allow public read/write to support mock/fallback users and registration search
    match /users/{userId} {
      allow read, write: if true;
    }

    // 3. Activity Logs - allow public read/write to ensure logs are fully functional for all sessions
    match /activity_logs/{logId} {
      allow read, write: if true;
    }
  }
}
